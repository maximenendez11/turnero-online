// Turnero: negocios, horarios, servicios y reservas públicas.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  ownedBusinesses Business[] @relation("BusinessOwner")

  @@map("users")
}

enum BusinessStatus {
  active
  inactive
}

/// Tramo horario en un día de la semana (weekday 0=domingo … 6=sábado, como Date.getUTCDay()).
/// Varios registros el mismo día = varios tramos; la pausa es el hueco entre tramos.
model BusinessOpeningWindow {
  id         String   @id @default(uuid())
  businessId String
  weekday    Int
  startMin   Int
  endMin     Int
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, weekday])
  @@map("business_opening_windows")
}

model Business {
  id                   String          @id @default(uuid())
  name                 String
  slug                 String?         @unique
  description          String?
  address              String
  timezone             String          @default("America/Argentina/Buenos_Aires")
  bookingIntervalMin   Int             @default(30)
  /// Color de fondo de la página pública de reserva (#RRGGBB), null = tema por defecto.
  themeBackgroundHex   String?         @map("theme_background_hex") @db.VarChar(7)
  /// Color primario / acento (#RRGGBB), null = tema por defecto.
  themePrimaryHex      String?         @map("theme_primary_hex") @db.VarChar(7)
  /// Imagen de cabecera en la landing pública (URL absoluta o relativa); null = imagen por defecto en el cliente.
  bannerImageUrl       String?         @map("banner_image_url") @db.VarChar(2048)
  /// Promedio de valoración mostrada al público (0–5); null si aún no hay reseñas.
  ratingAverage        Float?          @map("rating_average")
  /// Cantidad de valoraciones agregadas (futuro: reseñas reales).
  ratingCount          Int             @default(0) @map("rating_count")
  status               BusinessStatus  @default(active)
  ownerUserId          String?         @map("owner_user_id")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  deletedAt            DateTime?

  owner          User?                   @relation("BusinessOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  openingWindows BusinessOpeningWindow[]
  services       BusinessService[]
  staff          BusinessStaff[]
  bookings       Booking[]

  @@index([ownerUserId])
  @@map("businesses")
}

model BusinessService {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  description String?
  durationMin Int
  price       Decimal  @db.Decimal(10, 2)
  /// Si es true, el precio no se compromete (ej. «a consultar»); `price` puede ser 0.
  priceOnRequest Boolean @default(false) @map("price_on_request")
  /// Porcentaje de seña sugerida (0–100); null = no mostrar cálculo / sin seña fija.
  depositPercent Int?    @map("deposit_percent")
  modalityPresencial Boolean @default(true) @map("modality_presencial")
  modalityOnline     Boolean @default(false) @map("modality_online")
  modalityDomicilio  Boolean @default(false) @map("modality_domicilio")
  schedulingType    BusinessServiceSchedulingType @default(regular) @map("scheduling_type")
  /// Texto largo para recordatorios / condiciones (puntualidad, políticas, etc.).
  reminderClarifications String? @map("reminder_clarifications") @db.Text
  /// Imagen opcional para la vitrina pública (URL).
  imageUrl    String?  @map("image_url") @db.VarChar(2048)
  imageUrl2   String?  @map("image_url_2") @db.VarChar(2048)
  imageUrl3   String?  @map("image_url_3") @db.VarChar(2048)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business       Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings       Booking[]
  eligibleStaff  BusinessServiceStaff[]

  @@index([businessId])
  @@map("business_services")
}

/// Profesionales habilitados para este servicio. Sin filas = todos los del negocio.
model BusinessServiceStaff {
  serviceId String @map("service_id")
  staffId   String @map("staff_id")

  service BusinessService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff   BusinessStaff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@id([serviceId, staffId])
  @@index([staffId])
  @@map("business_service_staff")
}

/// Profesional mostrado en la landing pública del negocio.
model BusinessStaff {
  id          String   @id @default(uuid())
  businessId  String   @map("business_id")
  displayName String   @map("display_name")
  role        String?
  photoUrl    String?  @map("photo_url") @db.VarChar(2048)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  serviceAssignments BusinessServiceStaff[]

  @@index([businessId])
  @@map("business_staff")
}

enum BookingStatus {
  pending
  confirmed
  cancelled
}

/// Cómo se agenda el servicio en el catálogo (la lógica de turnos públicos sigue siendo por franjas por ahora).
enum BusinessServiceSchedulingType {
  regular
  variable_date
  cupos
}

model Booking {
  id               String        @id @default(uuid())
  code             String        @unique
  businessId       String
  serviceId        String
  customerFullName String
  customerContact  String
  startsAt         DateTime
  durationMin      Int
  status           BookingStatus @default(confirmed)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service  BusinessService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([businessId, startsAt])
  @@map("bookings")
}
