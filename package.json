{
  "name": "@proyecto-base/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "nx run-many --target=serve --projects=api,web --parallel",
    "build": "nx run-many --target=build --projects=api,web",
    "docker:up": "docker-compose -f docker/docker-compose.yml up --build",
    "docker:down": "docker-compose -f docker/docker-compose.yml down",
    "lint": "nx run-many --target=lint --all",
    "format": "prettier --write \"**/*.{ts,html,scss,json,md}\"",
    "prisma:generate": "cd api && npx prisma generate",
    "prisma:migrate": "cd api && npx prisma migrate dev",
    "prisma:migrate:deploy": "cd api && npx prisma migrate deploy",
    "prisma:seed": "cd api && npx prisma db seed",
    "postinstall": "npm run prisma:generate && patch-package"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "private": true,
  "devDependencies": {
