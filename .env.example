NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:4200

# URL base del API para el build del front (sin barra final). Nx ejecuta scripts/write-build-api-url.mjs antes de compilar web.
# En Coolify/Docker usar build-arg NX_API_URL o esta variable en buildtime.
NX_API_URL=http://localhost:3000/api
# Opcional: runtime en el navegador si inyectás window.__env (ver ConfigService).
API_URL=http://localhost:3000/api

DATABASE_URL=mysql://user:password@localhost:3306/dbname

JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

WEATHER_API_KEY=
GOOGLE_MAPS_API_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@example.com
MAIL_CONTACT_INBOX=
MAIL_CONTACT_CC=

# Optional: future provider switch
BACKEND_PROVIDER=nestjs
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
